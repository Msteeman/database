# ScoutingHub — voorbeeld-omgevingsvariabelen (PLACEHOLDERS)
#
# Dit bestand bevat ALLEEN placeholders. Vul NOOIT echte waarden in dit bestand
# in en commit NOOIT een echte `.env`. De echte waarden horen als Cloudflare
# Worker Secrets, niet in de repo.
#
# Zet een echte `.env` in `.gitignore`.

# Firebase Browser web-key (publieke web-key) — als Cloudflare Secret
GOOGLE_API_KEY=

# Resend — transactionele e-mails — als Cloudflare Secret
RESEND_API_KEY=

# Gemini — AI-proxy in de Worker — als Cloudflare Secret
GEMINI_API_KEY=

# Tournify — externe toernooi-API (publieke web-key extern project) — als Cloudflare Secret
TOURNIFY_API_KEY=

# Firebase service-account (toekomstige Admin SDK-fase) — als Cloudflare Secret
# Waarde = de volledige service-account-JSON. NOOIT in GitHub.
SERVICE_ACCOUNT_JSON=
